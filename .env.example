# =============================================================================
# Clinic scheduling voice agent — environment configuration
# Copy this file to `.env` and fill in your keys:  cp .env.example .env
# =============================================================================

# --- Required API keys -------------------------------------------------------
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ANTHROPIC_API_KEY=

# --- Provider selection (swapping a provider is a one-line change) -----------
# STT_PROVIDER: deepgram
STT_PROVIDER=deepgram
# LLM_PROVIDER: anthropic | openai | google
LLM_PROVIDER=anthropic
# TTS_PROVIDER: cartesia | deepgram | openai
TTS_PROVIDER=cartesia
# Automatic TTS failover target if the primary errors/times out.
# Defaults to deepgram (reuses DEEPGRAM_API_KEY — works with no extra keys).
# Leave empty to disable failover.
TTS_FALLBACK_PROVIDER=deepgram

# --- Models ------------------------------------------------------------------
DEEPGRAM_MODEL=nova-3-general
CARTESIA_MODEL=sonic-3.5
# CARTESIA_VOICE=71a7ad14-091c-4e8e-a314-022ece01c121

# Default is highest-quality Opus. For the ~800ms per-turn latency target,
# switch to a faster model — this is the recommended setting for the demo:
#   ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8

# Only needed if you set LLM_PROVIDER / TTS_PROVIDER to these:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.5-flash

# --- Optional: SMS confirmations (secondary; demo works without these) -------
# If all three are set, send_sms_confirmation() sends a real text via Twilio;
# otherwise it just logs the message.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# --- Stretch: telephony (does NOT affect the browser demo) -------------------
# Set true to also let the same agent answer an inbound Twilio/Telnyx call
# via the Pipecat runner's websocket transport.
ENABLE_TELEPHONY=false
