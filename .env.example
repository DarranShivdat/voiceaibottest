# =============================================================================
# Clinic new-patient intake voice agent — environment configuration
# Copy this file to `.env` and fill in your keys:  cp .env.example .env
# Fake-data demo: no real EMR, telephony, insurance APIs, or SMS/email.
# =============================================================================

# --- Required API keys -------------------------------------------------------
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ANTHROPIC_API_KEY=

# --- Provider selection (swapping a provider is a one-line change) -----------
# STT_PROVIDER: deepgram
STT_PROVIDER=deepgram
# LLM_PROVIDER: anthropic | openai | google
LLM_PROVIDER=anthropic
# TTS_PROVIDER: cartesia | deepgram | openai
TTS_PROVIDER=cartesia
# Automatic TTS failover target if the primary errors/times out.
# Defaults to deepgram (reuses DEEPGRAM_API_KEY — works with no extra keys).
# Leave empty to disable failover.
TTS_FALLBACK_PROVIDER=deepgram

# --- Models ------------------------------------------------------------------
DEEPGRAM_MODEL=nova-3-general
CARTESIA_MODEL=sonic-3.5
# CARTESIA_VOICE=71a7ad14-091c-4e8e-a314-022ece01c121

# Haiku is the default: lowest latency for real-time voice (the ~800ms per-turn
# target). Bump to claude-sonnet-4-6 if you want more reasoning headroom.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Flow config -------------------------------------------------------------
# JSON file that defines the conversation flow (nodes, questions, transitions,
# tool calls). Point at a different file to load a different clinic's flow.
FLOW_CONFIG=flows/penciled_test_clinic.json

# Only needed if you set LLM_PROVIDER / TTS_PROVIDER to these:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.5-flash

# --- Stretch: telephony (does NOT affect the browser demo) -------------------
# Off by default. When true, the same agent can also answer an inbound
# Twilio/Telnyx websocket via the Pipecat runner. Demo is browser-only.
ENABLE_TELEPHONY=false

# NOTE: appointment confirmations are MOCK (logged to console only) — there is
# no real SMS/email integration in this demo.
